# Deadlock detector runtime configuration
# Keep empty values to disable each filter.
TARGET_PIDS=
TARGET_CGROUP_IDS=
TARGET_COMM=

# 0 = suppress profiler-like processes, 1 = allow
ALLOW_PROFILER_SIGNALS=0

STATIC_FINDINGS_PATH=/opt/production-deadlock-detection/output/static_findings.csv
PROFILER_PATTERNS_PATH=/opt/production-deadlock-detection/output/profiler_filters.txt
